    {
      "key": {
        "uuid": "AAAA1H///jY\u003d",
        "filename": "src/com/android/phone/PhoneUtils.java",
        "patchSetId": 3
      },
      "lineNbr": 537,
      "author": {
        "id": 1004035
      },
      "writtenOn": "2010-07-15T11:33:00Z",
      "side": 1,
      "message": "audioOn is invoked as part of the handlePreciseCallStateChange and hence would be too late.\n\nPlease note that this is needed for the outgoing call initiated from the phone\u0027s keypad. Other scenarios: Incoming call, outgoing call from HF do not use this. \n\nI understand your concern, but placeCall is the single entry point for all outgoing calls initiated on the phone. The requirement is to terminate the virtual-call if any before dialing out. Please let me know if there is a more appropriate location to call this.",
      "parentUuid": "AAAA1H///vU\u003d",
      "revId": "5220be0794449ba6f66cc1c813e72c6a75694f1d",
      "serverId": "85c56323-6fa9-3386-8a01-6480fb634889",
