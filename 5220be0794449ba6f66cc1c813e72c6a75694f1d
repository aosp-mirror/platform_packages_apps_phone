        "patchSetId": 3
      },
      "lineNbr": 537,
      "author": {
        "id": 1000635
      },
      "writtenOn": "2010-07-14T17:45:45Z",
      "side": 1,
      "message": "I think u can move this to audioOn() ?\n\nThis is not safe, because a call could be initiated by the Phone app at various points. Putting an extra dependency on the phone app makes the code fragile. A developer adding a new entry point in the Phone app will not remember to do this.",
      "parentUuid": "AAAA1H///zY\u003d",
      "revId": "5220be0794449ba6f66cc1c813e72c6a75694f1d",
      "serverId": "85c56323-6fa9-3386-8a01-6480fb634889",
      "unresolved": false
